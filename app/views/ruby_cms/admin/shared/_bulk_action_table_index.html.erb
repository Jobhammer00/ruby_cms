<%# 
  Reusable bulk action table partial for index pages
  
  Locals:
  - title: Page title (rendered outside the table)
  - collection: Array of items to display
  - headers: Array of header strings or hashes with { text: "...", class: "..." }
  - action_icons: Array of icon configs { url: "...", title: "...", data: {...} }
  - search_url: URL for search form
  - search_param: Search parameter name (default: "q")
  - turbo_frame: Turbo frame ID (default: "admin_table_content")
  - bulk_actions_url: URL for bulk delete
  - bulk_action_buttons: Array of bulk action button configs
  - item_name: Singular name for items (e.g., "user", "permission")
  - pagination: Pagination hash
  - pagination_path: Lambda for pagination URLs
  - row_partial: Partial name for rendering each row (e.g., "users/row")
  - row_block: Block for rendering rows (alternative to row_partial)
-%>
<% title = local_assigns[:title] %>
<% collection = local_assigns[:collection] || [] %>
<% headers = local_assigns[:headers] || [] %>
<% action_icons = local_assigns[:action_icons] || [] %>
<% search_url = local_assigns[:search_url] || "#" %>
<% search_param = local_assigns[:search_param] || "q" %>
<% turbo_frame = local_assigns[:turbo_frame] || "admin_table_content" %>
<% bulk_actions_url = local_assigns[:bulk_actions_url] %>
<% bulk_action_buttons = local_assigns[:bulk_action_buttons] || [] %>
<% item_name = local_assigns[:item_name] || "item" %>
<% pagination = local_assigns[:pagination] %>
<% pagination_path = local_assigns[:pagination_path] %>
<% row_partial = local_assigns[:row_partial] %>
<% row_block = local_assigns[:row_block] %>

<% if title %>
  <%= tag.h1 title, class: "ruby_cms-page-title" %>
<% end %>

<%= render RubyCms::Admin::BulkActionTable::BulkActionTable.new(
  header: capture do %>
    <%= tag.div class: "bulk-action-table__header-content", style: "display: flex; align-items: center; justify-content: space-between; width: 100%;" do %>
      <% if action_icons.any? %>
        <%= tag.div class: "ruby_cms-page-header__action-icons" do %>
          <% action_icons.each do |icon_config| %>
            <%= link_to icon_config[:url] || "#", 
                class: "ruby_cms-page-header__icon-action ruby_cms-page-header__icon-action--#{icon_config[:color] || 'blue'}", 
                title: icon_config[:title],
                data: icon_config[:data] || {} do %>
              <%= tag.svg class: "ruby_cms-page-header__icon", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" do %>
                <%= tag.path stroke_linecap: "round", stroke_linejoin: "round", stroke_width: "2", d: icon_config[:icon] || "M12 4.5v15m7.5-7.5h-15" %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% else %>
        <%= tag.div %>
      <% end %>
      <%= form_with url: search_url, method: :get, class: "ruby_cms-page-header__search-form", data: { turbo_frame: turbo_frame } do %>
        <%= tag.div class: "ruby_cms-page-header__search-wrapper" do %>
          <%= tag.svg class: "ruby_cms-page-header__search-icon", fill: "none", stroke: "currentColor", viewBox: "0 0 24 24" do %>
            <%= tag.path stroke_linecap: "round", stroke_linejoin: "round", stroke_width: "2", d: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" %>
          <% end %>
          <%= tag.input type: "search", name: search_param, placeholder: "Search", class: "ruby_cms-page-header__search-input", value: params[search_param.to_sym], data: { action: "input->turbo-frame#submit" } %>
        <% end %>
      <% end %>
    <% end %>
  <% end,
  turbo_frame: turbo_frame,
  pagination: pagination,
  pagination_path: pagination_path,
  bulk_actions_url: bulk_actions_url,
  bulk_actions_buttons: bulk_action_buttons,
  item_name: item_name,
  controller_name: "ruby-cms--bulk-action-table",
  csrf_token: form_authenticity_token
) do %>
  <%= render RubyCms::Admin::BulkActionTable::BulkActionTableHeader.new(
    headers: headers,
    bulk_actions_enabled: true,
    controller_name: "ruby-cms--bulk-action-table"
  ) %>
  
  <%= render RubyCms::Admin::BulkActionTable::BulkActionTableBody.new do %>
    <% collection.each do |item| %>
      <% next if item.nil? %>
      <%= render RubyCms::Admin::BulkActionTable::BulkActionTableRow.new(
        data: { item_id: item.id },
        bulk_actions_enabled: true,
        controller_name: "ruby-cms--bulk-action-table"
      ) do %>
        <% if row_partial %>
          <%# Map item to the correct local variable name based on item_name %>
          <% item_var = item_name.singularize.to_sym %>
          <%= render partial: row_partial, locals: { item_var => item } %>
        <% elsif row_block %>
          <%= row_block.call(item) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
