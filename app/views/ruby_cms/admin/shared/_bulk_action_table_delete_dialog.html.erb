<%# Bulk Action Table Delete Dialog %>
<%# This partial renders a dialog for confirming bulk delete actions %>
<% controller_name = local_assigns[:controller_name] || "ruby-cms--bulk-action-table" %>

<div data-<%= controller_name %>-target="dialogOverlay" class="bulk-action-dialog hidden" role="dialog" aria-modal="true" aria-labelledby="dialog-title" data-action="keydown-><%= controller_name %>#handleKeydown">
  <%# Backdrop %>
  <div class="bulk-action-dialog__backdrop" data-action="click-><%= controller_name %>#closeDialog"></div>
  
  <%# Dialog container %>
  <div class="bulk-action-dialog__container">
    <div data-<%= controller_name %>-target="dialogContent" class="bulk-action-dialog__content" tabindex="-1">
      <%# Close button %>
      <button
        type="button"
        class="bulk-action-dialog__close"
        data-action="click-><%= controller_name %>#closeDialog"
        aria-label="Close"
      >
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg" class="bulk-action-dialog__close-icon">
          <path d="M11.7816 4.03157C12.0062 3.80702 12.0062 3.44295 11.7816 3.2184C11.5571 2.99385 11.193 2.99385 10.9685 3.2184L7.50005 6.68682L4.03164 3.2184C3.80708 2.99385 3.44301 2.99385 3.21846 3.2184C2.99391 3.44295 2.99391 3.80702 3.21846 4.03157L6.68688 7.49999L3.21846 10.9684C2.99391 11.193 2.99391 11.557 3.21846 11.7816C3.44301 12.0061 3.80708 12.0061 4.03164 11.7816L7.50005 8.31316L10.9685 11.7816C11.193 12.0061 11.5571 12.0061 11.7816 11.7816C12.0062 11.557 12.0062 11.193 11.7816 10.9684L8.31322 7.49999L11.7816 4.03157Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
        </svg>
        <span class="sr-only">Close</span>
      </button>
      
      <%# Header %>
      <div class="bulk-action-dialog__header">
        <h3 id="dialog-title" data-<%= controller_name %>-target="dialogTitle" class="bulk-action-dialog__title">
          Delete Selected Items
        </h3>
      </div>
      
      <%# Message %>
      <div data-<%= controller_name %>-target="dialogMessage" class="bulk-action-dialog__message">
        <p>Are you sure you want to delete the selected items?</p>
        <p>This action cannot be undone.</p>
      </div>
      
      <%# Footer with actions %>
      <div class="bulk-action-dialog__footer">
        <button
          type="button"
          class="bulk-action-dialog__button"
          data-action="click-><%= controller_name %>#closeDialog"
        >
          Cancel
        </button>
        <button
          type="button"
          data-<%= controller_name %>-target="dialogConfirmButton"
          data-action="click-><%= controller_name %>#confirmAction"
          class="bulk-action-dialog__button bulk-action-dialog__button--confirm"
        >
          Delete Selected
        </button>
      </div>
    </div>
  </div>
</div>

