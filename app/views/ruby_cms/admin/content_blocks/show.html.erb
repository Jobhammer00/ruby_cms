<div class="ruby_cms-page-header ruby_cms-content-blocks-edit-header">
  <div class="ruby_cms-page-header__content">
    <div class="ruby_cms-page-header__title-group">
      <h1 class="ruby_cms-page-title">Content block</h1>
    </div>

    <div class="ruby_cms-page-header__action-icons">
      <%= link_to "Edit",
                  edit_ruby_cms_admin_content_block_path(@content_block),
                  class: "ruby_cms-pelican-button ruby_cms-pelican-button--primary" %>

      <%= link_to "Back",
                  ruby_cms_admin_content_blocks_path,
                  class: "ruby_cms-pelican-button ruby_cms-pelican-button--ghost" %>
    </div>
  </div>
</div>

<div class="ruby_cms-pelican-card ruby_cms-content-blocks-show">

  <div class="ruby_cms-content-blocks-show__meta">
    <div>
      <div class="ruby_cms-content-blocks-show__label">ID</div>
      <div class="ruby_cms-content-blocks-show__value"><%= @content_block.id %></div>
    </div>

    <div>
      <div class="ruby_cms-content-blocks-show__label">Key</div>
      <div class="ruby_cms-content-blocks-show__value ruby_cms-content-blocks-show__mono"><%= @content_block.key %></div>
    </div>

    <div>
      <div class="ruby_cms-content-blocks-show__label">Locale</div>
      <div class="ruby_cms-content-blocks-show__value"><%= ruby_cms_locale_display_name(@content_block.locale) %></div>
    </div>

    <div>
      <div class="ruby_cms-content-blocks-show__label">Type</div>
      <div class="ruby_cms-content-blocks-show__value"><%= @content_block.content_type %></div>
    </div>

    <div>
      <div class="ruby_cms-content-blocks-show__label">Published</div>
      <div class="ruby_cms-content-blocks-show__value">
        <% if @content_block.published? %>
          <span class="ruby_cms-status-pill ruby_cms-status-pill--success">Published</span>
        <% else %>
          <span class="ruby_cms-status-pill ruby_cms-status-pill--muted">Draft</span>
        <% end %>
      </div>
    </div>

    <div>
      <div class="ruby_cms-content-blocks-show__label">Created At</div>
      <div class="ruby_cms-content-blocks-show__value"><%= @content_block.created_at.strftime("%B %d, %Y at %I:%M %p") %></div>
    </div>

    <div>
      <div class="ruby_cms-content-blocks-show__label">Last Updated</div>
      <div class="ruby_cms-content-blocks-show__value"><%= @content_block.updated_at.strftime("%B %d, %Y at %I:%M %p") %></div>
    </div>

    <% if @content_block.updated_by.present? %>
      <div>
        <div class="ruby_cms-content-blocks-show__label">Updated By</div>
        <div class="ruby_cms-content-blocks-show__value"><%= @content_block.updated_by.email %></div>
      </div>
    <% end %>
  </div>

  <% if @blocks_by_locale.present? %>
    <div class="ruby_cms-content-blocks-show__locales">
      <% @blocks_by_locale.each do |locale_s, block| %>
        <div class="ruby_cms-content-blocks-show__locale-card">
          <div class="ruby_cms-content-blocks-show__locale-header">
            <span class="ruby_cms-content-blocks-show__locale-pill">
              <%= ruby_cms_locale_display_name(locale_s) %>
            </span>
          </div>

          <div class="ruby_cms-content-blocks-show__fields">
            <div>
              <div class="ruby_cms-content-blocks-show__label">Title</div>
              <div class="ruby_cms-content-blocks-show__value"><%= block.title.presence || "—" %></div>
            </div>

            <div class="ruby_cms-content-blocks-show__field-full">
              <div class="ruby_cms-content-blocks-show__label">Content</div>
              <div class="ruby_cms-content-blocks-show__value ruby_cms-content-blocks-show__content">
                <%= block.content_body.presence || "—" %>
              </div>
            </div>

            <% if block.respond_to?(:rich_content) && block.rich_content.present? %>
              <div class="ruby_cms-content-blocks-show__field-full">
                <div class="ruby_cms-content-blocks-show__label">Rich content</div>
                <div class="ruby_cms-content-blocks-show__value ruby_cms-content-blocks-show__rich-content">
                  <%= block.rich_content %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%# fallback single-locale %>
    <div class="ruby_cms-content-blocks-show__single">
      <div>
        <div class="ruby_cms-content-blocks-show__label">Title</div>
        <div class="ruby_cms-content-blocks-show__value"><%= @content_block.title %></div>
      </div>

      <div>
        <div class="ruby_cms-content-blocks-show__label">Content</div>
        <div class="ruby_cms-content-blocks-show__value ruby_cms-content-blocks-show__content">
          <%= @content_block.content_body %>
        </div>
      </div>
    </div>
  <% end %>

</div>
