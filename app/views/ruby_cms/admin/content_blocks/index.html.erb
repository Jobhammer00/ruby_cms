<div class="ruby_cms-page-header flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Content blocks</h1>
  <%= link_to "New content block", new_ruby_cms_admin_content_block_path, class: "ruby_cms-btn ruby_cms-btn-primary inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700" %>
</div>

<div class="ruby_cms-card ruby_cms-table-wrap bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="ruby_cms-table min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Key</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Published</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @content_blocks.each do |block| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-sm text-gray-900"><%= block.key %></td>
          <td class="px-4 py-3 text-sm text-gray-900"><%= block.title %></td>
          <td class="px-4 py-3 text-sm text-gray-600"><%= block.content_type %></td>
          <td class="px-4 py-3 text-sm"><%= block.published? ? tag.span("Yes", class: "ruby_cms-badge ruby_cms-badge-success px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800") : tag.span("No", class: "ruby_cms-badge ruby_cms-badge-muted px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600") %></td>
          <td class="actions px-4 py-3 text-sm text-right space-x-2">
            <%= link_to "Show", ruby_cms_admin_content_block_path(block), class: "ruby_cms-link text-blue-600 hover:text-blue-800" %>
            <%= link_to "Edit", edit_ruby_cms_admin_content_block_path(block), class: "ruby_cms-link text-blue-600 hover:text-blue-800" %>
            <%= button_to "Delete", ruby_cms_admin_content_block_path(block), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "ruby_cms-link ruby_cms-link-danger inline text-red-600 hover:text-red-800" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
