<%
  bulk_action_buttons = []
  begin
    bulk_publish_url = bulk_publish_ruby_cms_admin_content_blocks_path
    bulk_action_buttons << {
      name: "publish",
      label: "Publish Selected",
      url: bulk_publish_url,
      confirm: "Are you sure you want to publish the selected content blocks?"
    }
  rescue NoMethodError, ActionController::UrlGenerationError
  end
  
  begin
    bulk_unpublish_url = bulk_unpublish_ruby_cms_admin_content_blocks_path
    bulk_action_buttons << {
      name: "unpublish",
      label: "Unpublish Selected",
      url: bulk_unpublish_url,
      confirm: "Are you sure you want to unpublish the selected content blocks?"
    }
  rescue NoMethodError, ActionController::UrlGenerationError
  end
  
  begin
    bulk_delete_url = bulk_delete_ruby_cms_admin_content_blocks_path
  rescue NoMethodError, ActionController::UrlGenerationError
    bulk_delete_url = nil
  end
%>

  <div class="mb-4">
    <h1 class="text-2xl font-semibold text-foreground">Content blocks</h1>
    <p class="mt-1 text-sm text-muted-foreground">
      <%= number_with_delimiter(@pagination&.dig(:total_count) || @content_blocks&.size || 0) %> total items
    </p>
  </div>

  <%= render partial: "ruby_cms/admin/shared/bulk_action_table_index", locals: {
    title: nil,
    collection: @content_blocks || [],
    headers: ["Key", "Locale", "Title", "Type", "Published", { text: "Actions", class: "text-right" }],
    action_icons: [
      {
        url: new_ruby_cms_admin_content_block_path,
        title: "New content block",
        color: "blue",
        icon: "M12 4.5v15m7.5-7.5h-15",
        data: { turbo_frame: "_top" }
      }
    ],
    search_url: ruby_cms_admin_content_blocks_path,
    search_param: "q",
    turbo_frame: "admin_table_content",
    bulk_actions_url: bulk_delete_url,
    bulk_action_buttons: bulk_action_buttons,
    item_name: "content block",
    pagination: @pagination,
    pagination_path: @pagination_path,
    row_partial: "ruby_cms/admin/content_blocks/row",
    row_click_url: ->(item) { ruby_cms_admin_content_block_path(item.respond_to?(:content_block) ? item.content_block : item) }
  } %>
