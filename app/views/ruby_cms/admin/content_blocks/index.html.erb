<%# Phlex-based Bulk Action Table View %>
<%
  # Build bulk action buttons
  bulk_action_buttons = []
  begin
    bulk_publish_url = bulk_publish_ruby_cms_admin_content_blocks_path
    bulk_action_buttons << {
      name: "publish",
      label: "Publish Selected",
      url: bulk_publish_url,
      confirm: "Are you sure you want to publish the selected content blocks?"
    }
  rescue NoMethodError, ActionController::UrlGenerationError
  end
  
  begin
    bulk_unpublish_url = bulk_unpublish_ruby_cms_admin_content_blocks_path
    bulk_action_buttons << {
      name: "unpublish",
      label: "Unpublish Selected",
      url: bulk_unpublish_url,
      confirm: "Are you sure you want to unpublish the selected content blocks?"
    }
  rescue NoMethodError, ActionController::UrlGenerationError
  end
  
  begin
    bulk_delete_url = bulk_delete_ruby_cms_admin_content_blocks_path
  rescue NoMethodError, ActionController::UrlGenerationError
    bulk_delete_url = nil
  end
%>

<%= render RubyCms::Admin::AdminPage.new(
  title: "Content blocks",
  actions: [
    { label: "New content block", url: new_ruby_cms_admin_content_block_path, primary: true }
  ]
) do %>
  <div class="ruby_cms-card">
    <%= render RubyCms::Admin::BulkActionTable::BulkActionTable.new(
      turbo_frame: "admin_table_content",
      pagination: @pagination,
      pagination_path: @pagination_path,
      bulk_actions_url: bulk_delete_url,
      bulk_actions_buttons: bulk_action_buttons,
      item_name: "content block",
      controller_name: "ruby-cms--bulk-action-table",
      csrf_token: form_authenticity_token
    ) do %>
      <%= render RubyCms::Admin::BulkActionTable::BulkActionTableHeader.new(
        headers: ["Key", "Title", "Type", "Published", { text: "Actions", class: "text-right" }],
        bulk_actions_enabled: true,
        controller_name: "ruby-cms--bulk-action-table"
      ) %>
      
      <%= render RubyCms::Admin::BulkActionTable::BulkActionTableBody.new do %>
        <% (@content_blocks || []).each do |block| %>
          <% next if block.nil? %>
          <%= render RubyCms::Admin::BulkActionTable::BulkActionTableRow.new(
            data: { item_id: block.id },
            bulk_actions_enabled: true,
            controller_name: "ruby-cms--bulk-action-table"
          ) do %>
            <td><%= block.key %></td>
            <td><%= block.title %></td>
            <td class="text-muted"><%= block.content_type %></td>
            <td>
              <%= block.published? ? tag.span("Yes", class: "ruby_cms-badge ruby_cms-badge-success") : tag.span("No", class: "ruby_cms-badge ruby_cms-badge-muted") %>
            </td>
            <td class="text-right">
              <%= render RubyCms::Admin::BulkActionTable::BulkActionTableActions.new(
                edit_path: edit_ruby_cms_admin_content_block_path(block),
                delete_path: ruby_cms_admin_content_block_path(block),
                item_id: block.id,
                controller_name: "ruby-cms--bulk-action-table"
              ) %>
            </td>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>
