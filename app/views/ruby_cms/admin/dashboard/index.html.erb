<div class="ruby_cms-dashboard-header">
  <div>
    <h1 class="ruby_cms-page-title">Dashboard</h1>
    <p class="ruby_cms-dashboard-subtitle">Welcome back! Here's an overview of your CMS.</p>
  </div>
</div>

<div class="ruby_cms-dashboard-grid">
  <%# Content Blocks Card %>
  <div class="ruby_cms-dashboard-card">
    <div class="ruby_cms-dashboard-card-body">
      <div class="ruby_cms-dashboard-card-icon ruby_cms-dashboard-card-icon--blue">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
        </svg>
      </div>
      <div class="ruby_cms-dashboard-card-content">
        <div class="ruby_cms-dashboard-card-label">Content Blocks</div>
        <div class="ruby_cms-dashboard-card-value">
          <span class="ruby_cms-dashboard-card-number"><%= @content_blocks_count %></span>
          <span class="ruby_cms-dashboard-card-subtext ruby_cms-dashboard-card-subtext--success"><%= @content_blocks_published_count %> published</span>
        </div>
      </div>
    </div>
    <div class="ruby_cms-dashboard-card-footer">
      <%= link_to "Manage content blocks →", ruby_cms_admin_content_blocks_path, class: "ruby_cms-dashboard-card-link" %>
    </div>
  </div>

  <%# Users Card %>
  <div class="ruby_cms-dashboard-card">
    <div class="ruby_cms-dashboard-card-body">
      <div class="ruby_cms-dashboard-card-icon ruby_cms-dashboard-card-icon--green">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
        </svg>
      </div>
      <div class="ruby_cms-dashboard-card-content">
        <div class="ruby_cms-dashboard-card-label">Users</div>
        <div class="ruby_cms-dashboard-card-value">
          <span class="ruby_cms-dashboard-card-number"><%= @users_count %></span>
          <span class="ruby_cms-dashboard-card-subtext">registered</span>
        </div>
      </div>
    </div>
    <div class="ruby_cms-dashboard-card-footer">
      <%= link_to "Manage users →", ruby_cms_admin_users_path, class: "ruby_cms-dashboard-card-link" %>
    </div>
  </div>

  <%# Permissions Card %>
  <div class="ruby_cms-dashboard-card">
    <div class="ruby_cms-dashboard-card-body">
      <div class="ruby_cms-dashboard-card-icon ruby_cms-dashboard-card-icon--purple">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
      </div>
      <div class="ruby_cms-dashboard-card-content">
        <div class="ruby_cms-dashboard-card-label">Permissions</div>
        <div class="ruby_cms-dashboard-card-value">
          <span class="ruby_cms-dashboard-card-number"><%= @permissions_count %></span>
          <span class="ruby_cms-dashboard-card-subtext">defined (<%= @user_permissions_count %> grants)</span>
        </div>
      </div>
    </div>
    <div class="ruby_cms-dashboard-card-footer">
      <%= link_to "Manage permissions →", ruby_cms_admin_permissions_path, class: "ruby_cms-dashboard-card-link" %>
    </div>
  </div>

  <%# Visitor Errors Card %>
  <div class="ruby_cms-dashboard-card">
    <div class="ruby_cms-dashboard-card-body">
      <div class="ruby_cms-dashboard-card-icon ruby_cms-dashboard-card-icon--red">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
      </div>
      <div class="ruby_cms-dashboard-card-content">
        <div class="ruby_cms-dashboard-card-label">Visitor Errors</div>
        <div class="ruby_cms-dashboard-card-value">
          <span class="ruby_cms-dashboard-card-number"><%= @visitor_errors_count %></span>
          <% if @unresolved_errors_count > 0 %>
            <span class="ruby_cms-dashboard-card-subtext ruby_cms-dashboard-card-subtext--danger"><%= @unresolved_errors_count %> unresolved</span>
          <% else %>
            <span class="ruby_cms-dashboard-card-subtext">all resolved</span>
          <% end %>
        </div>
      </div>
    </div>
    <div class="ruby_cms-dashboard-card-footer">
      <%= link_to "View errors →", ruby_cms_admin_visitor_errors_path, class: "ruby_cms-dashboard-card-link" %>
    </div>
  </div>
</div>

<%# Quick Actions Section %>
<div class="ruby_cms-dashboard-section">
  <h2 class="ruby_cms-dashboard-section-title">Quick Actions</h2>
  <div class="ruby_cms-dashboard-quick-actions">
    <%= link_to new_ruby_cms_admin_content_block_path, class: "ruby_cms-btn ruby_cms-btn-primary" do %>
      <svg class="ruby_cms-btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      New Content Block
    <% end %>
    <%= link_to ruby_cms_admin_visual_editor_path, class: "ruby_cms-btn ruby_cms-btn-secondary" do %>
      <svg class="ruby_cms-btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
      </svg>
      Visual Editor
    <% end %>
    <%= link_to ruby_cms_admin_visitor_errors_path, class: "ruby_cms-btn ruby_cms-btn-secondary" do %>
      <svg class="ruby_cms-btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
      </svg>
      View Errors
    <% end %>
    <%= link_to ruby_cms_admin_settings_path, class: "ruby_cms-btn ruby_cms-btn-secondary" do %>
      <svg class="ruby_cms-btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      Settings
    <% end %>
  </div>
</div>

<%# Recent Activity Section %>
<h2 class="ruby_cms-dashboard-section-title">Recent Activity</h2>
<div class="ruby_cms-dashboard-activity-grid">
  <%# Recent Content Blocks %>
  <div class="ruby_cms-card ruby_cms-card--padded">
    <div class="ruby_cms-dashboard-activity-header">
      <h2 class="ruby_cms-card-title">Recent Content</h2>
      <%= link_to "View all →", ruby_cms_admin_content_blocks_path, class: "ruby_cms-dashboard-activity-link" %>
    </div>
    <% if @recent_content_blocks.any? %>
      <div class="ruby_cms-dashboard-activity-list">
        <% @recent_content_blocks.each do |block| %>
          <div class="ruby_cms-dashboard-activity-item">
            <div class="ruby_cms-dashboard-activity-item-content">
              <div class="ruby_cms-dashboard-activity-item-title"><%= block.key %></div>
              <div class="ruby_cms-dashboard-activity-item-meta">
                <span class="ruby_cms-dashboard-activity-item-status ruby_cms-dashboard-activity-item-status--<%= block.published? ? 'success' : 'muted' %>">
                  <%= block.published? ? 'Published' : 'Draft' %>
                </span>
                <span class="ruby_cms-dashboard-activity-item-time">
                  Updated <%= time_ago_in_words(block.updated_at) %> ago
                </span>
              </div>
            </div>
            <%= link_to "Edit", edit_ruby_cms_admin_content_block_path(block), class: "ruby_cms-dashboard-activity-item-action" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="ruby_cms-dashboard-activity-empty">No content blocks yet</p>
    <% end %>
  </div>

  <%# Recent Errors %>
  <div class="ruby_cms-card ruby_cms-card--padded">
    <div class="ruby_cms-dashboard-activity-header">
      <h2 class="ruby_cms-card-title">Recent Errors</h2>
      <%= link_to "View all →", ruby_cms_admin_visitor_errors_path, class: "ruby_cms-dashboard-activity-link" %>
    </div>
    <% if @recent_errors.any? %>
      <div class="ruby_cms-dashboard-activity-list">
        <% @recent_errors.each do |error| %>
          <div class="ruby_cms-dashboard-activity-item">
            <div class="ruby_cms-dashboard-activity-item-content">
              <div class="ruby_cms-dashboard-activity-item-title"><%= error.error_class %>: <%= error.error_message.truncate(60) %></div>
              <div class="ruby_cms-dashboard-activity-item-meta">
                <span class="ruby_cms-dashboard-activity-item-status ruby_cms-dashboard-activity-item-status--<%= error.resolved? ? 'success' : 'danger' %>">
                  <%= error.resolved? ? 'Resolved' : 'Unresolved' %>
                </span>
                <span class="ruby_cms-dashboard-activity-item-time">
                  <%= time_ago_in_words(error.created_at) %> ago
                </span>
              </div>
            </div>
            <%= link_to "View", ruby_cms_admin_visitor_error_path(error), class: "ruby_cms-dashboard-activity-item-action" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="ruby_cms-dashboard-activity-empty">No errors recorded</p>
    <% end %>
  </div>
</div>
