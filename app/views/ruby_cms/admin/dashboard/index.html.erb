<h1 class="text-2xl font-semibold text-gray-900 mb-4">Dashboard</h1>

<div class="ruby_cms-card ruby_cms-card--padded mb-6 p-4 bg-white rounded-lg border border-gray-200 shadow-sm">
  <p class="text-gray-700">
    <span class="font-medium">Content blocks:</span> <%= @content_blocks_count %> total, <%= @content_blocks_published_count %> published.
  </p>
</div>

<%= link_to "Content blocks", ruby_cms_admin_content_blocks_path, class: "ruby_cms-btn ruby_cms-btn-primary inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
