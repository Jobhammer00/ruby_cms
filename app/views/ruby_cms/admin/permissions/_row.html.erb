<%# Row partial for permissions table %>
<% permission = local_assigns[:permission] %>
<%= tag.td permission.key, class: "px-6 py-3 font-medium text-gray-900" %>
<%= tag.td permission.name, class: "px-6 py-3 text-gray-700" %>
<%= tag.td class: "px-6 py-3 text-right" do %>
  <%= render RubyCms::Admin::BulkActionTable::BulkActionTableActions.new(
    delete_path: ruby_cms_admin_permission_path(permission),
    item_id: permission.id,
    controller_name: "ruby-cms--bulk-action-table"
  ) %>
<% end %>
