<h1 class="text-2xl font-semibold text-gray-900 mb-4">Permissions</h1>

<div class="ruby_cms-card ruby_cms-table-wrap bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden mb-6">
  <table class="ruby_cms-table min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Key</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @permissions.each do |p| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-sm text-gray-900"><%= p.key %></td>
          <td class="px-4 py-3 text-sm text-gray-600"><%= p.name %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= link_to "Users", ruby_cms_admin_users_path, class: "ruby_cms-btn ruby_cms-btn-secondary inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50" %>
