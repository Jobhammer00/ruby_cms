<%
  begin
    bulk_delete_url = bulk_delete_ruby_cms_admin_permissions_path
  rescue NoMethodError, ActionController::UrlGenerationError
    bulk_delete_url = nil
  end
%>

<%= render RubyCms::Admin::AdminPage.new do %>
  <% if flash[:alert] %>
    <%= tag.div class: "ruby_cms-alert ruby_cms-alert--error" do %>
      <%= tag.p flash[:alert] %>
    <% end %>
  <% end %>

  <%= tag.div id: "new-permission-form", class: "hidden ruby_cms-card ruby_cms-card--padded ruby_cms-card--form" do %>
    <%= tag.h2 "Create Permission", class: "ruby_cms-card-title" %>
    <%= form_with model: [:ruby_cms_admin, RubyCms::Permission.new], url: ruby_cms_admin_permissions_path, method: :post, class: "ruby_cms-form" do |f| %>
      <%= tag.div class: "ruby_cms-field" do %>
        <%= f.label :key, class: "ruby_cms-label" %>
        <%= f.text_field :key, class: "ruby_cms-input", placeholder: "manage_something" %>
        <%= tag.p "URL-friendly key (e.g. manage_something)", class: "ruby_cms-hint" %>
      <% end %>
      <%= tag.div class: "ruby_cms-field" do %>
        <%= f.label :name, class: "ruby_cms-label" %>
        <%= f.text_field :name, class: "ruby_cms-input", placeholder: "Manage Something" %>
      <% end %>
      <%= tag.div class: "ruby_cms-button-group" do %>
        <%= f.submit "Create Permission", class: "ruby_cms-btn ruby_cms-btn-primary" %>
        <%= tag.button "Cancel", type: "button", class: "ruby_cms-btn ruby_cms-btn-secondary", data: { controller: "ruby-cms--toggle", action: "click->ruby-cms--toggle#hide", toggle_target_id: "new-permission-form" } %>
      <% end %>
    <% end %>
  <% end %>

  <%= render partial: "ruby_cms/admin/shared/bulk_action_table_index", locals: {
    title: "Permissions",
    collection: @permissions || [],
    headers: ["Key", "Name", { text: "Actions", class: "text-right" }],
    action_icons: [
      {
        url: "#",
        title: "New permission",
        color: "blue",
        icon: "M12 4.5v15m7.5-7.5h-15",
        data: {
          controller: "ruby-cms--toggle",
          action: "click->ruby-cms--toggle#toggle",
          toggle_target_id: "new-permission-form"
        }
      }
    ],
    search_url: ruby_cms_admin_permissions_path,
    search_param: "q",
    turbo_frame: "admin_table_content",
    bulk_actions_url: bulk_delete_url,
    bulk_action_buttons: [],
    item_name: "permission",
    pagination: @pagination,
    pagination_path: @pagination_path,
    row_partial: "ruby_cms/admin/permissions/row"
  } %>
<% end %>
