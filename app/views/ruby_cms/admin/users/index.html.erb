<h1 class="text-2xl font-semibold text-gray-900 mb-4">Users</h1>

<div class="ruby_cms-card ruby_cms-table-wrap bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
  <table class="ruby_cms-table min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @users.each do |u| %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-sm text-gray-900"><%= u.id %></td>
          <td class="px-4 py-3 text-sm text-gray-900"><%= u.try(:email_address) || u.try(:email) || u.to_s %></td>
          <td class="actions px-4 py-3 text-sm text-right"><%= link_to "Permissions", ruby_cms_admin_user_permissions_path(u), class: "ruby_cms-link text-blue-600 hover:text-blue-800" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
