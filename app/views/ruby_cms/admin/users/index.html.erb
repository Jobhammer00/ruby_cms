<%
  begin
    bulk_delete_url = bulk_delete_ruby_cms_admin_users_path
  rescue NoMethodError, ActionController::UrlGenerationError
    bulk_delete_url = nil
  end
  
  user_class = Object.const_get(Rails.application.config.ruby_cms.user_class_name.presence || "User")
  email_attr = user_class.column_names.include?("email_address") ? :email_address : :email
%>

<%= render RubyCms::Admin::AdminPage.new do %>
  <% if flash[:alert] %>
    <%= tag.div class: "ruby_cms-alert ruby_cms-alert--error" do %>
      <%= tag.p flash[:alert] %>
    <% end %>
  <% end %>

  <%= tag.div id: "new-user-form", class: "hidden ruby_cms-card ruby_cms-card--padded ruby_cms-card--form" do %>
    <%= tag.h2 "Create User", class: "ruby_cms-card-title" %>
    <%= form_with url: ruby_cms_admin_users_path, method: :post, class: "ruby_cms-form" do |f| %>
      <%= tag.div class: "ruby_cms-field" do %>
        <%= f.label email_attr, class: "ruby_cms-label" %>
        <%= f.text_field email_attr, class: "ruby_cms-input", placeholder: "user@example.com" %>
      <% end %>
      <% if user_class.column_names.include?("password") %>
        <%= tag.div class: "ruby_cms-field" do %>
          <%= f.label :password, class: "ruby_cms-label" %>
          <%= f.password_field :password, class: "ruby_cms-input" %>
        <% end %>
        <%= tag.div class: "ruby_cms-field" do %>
          <%= f.label :password_confirmation, "Password Confirmation", class: "ruby_cms-label" %>
          <%= f.password_field :password_confirmation, class: "ruby_cms-input" %>
        <% end %>
      <% end %>
      <%= tag.div class: "ruby_cms-button-group" do %>
        <%= f.submit "Create User", class: "ruby_cms-btn ruby_cms-btn-primary" %>
        <%= tag.button "Cancel", type: "button", class: "ruby_cms-btn ruby_cms-btn-secondary", data: { controller: "ruby-cms--toggle", action: "click->ruby-cms--toggle#hide", toggle_target_id: "new-user-form" } %>
      <% end %>
    <% end %>
  <% end %>

  <%= render partial: "ruby_cms/admin/shared/bulk_action_table_index", locals: {
    title: "Users",
    collection: @users || [],
    headers: ["ID", "Email", { text: "Actions", class: "text-right" }],
    action_icons: [
      {
        url: "#",
        title: "New user",
        color: "blue",
        icon: "M12 4.5v15m7.5-7.5h-15",
        data: {
          controller: "ruby-cms--toggle",
          action: "click->ruby-cms--toggle#toggle",
          toggle_target_id: "new-user-form"
        }
      }
    ],
    search_url: ruby_cms_admin_users_path,
    search_param: "q",
    turbo_frame: "admin_table_content",
    bulk_actions_url: bulk_delete_url,
    bulk_action_buttons: [],
    item_name: "user",
    pagination: @pagination,
    pagination_path: @pagination_path,
    row_partial: "ruby_cms/admin/users/row"
  } %>
<% end %>
