<div class="rounded-xl border border-border/60 bg-white shadow-sm overflow-hidden">
  <div class="flex items-center gap-3 px-4 py-3 border-b border-border/40">
    <div class="rounded-md bg-amber-50 p-1.5 flex-shrink-0">
      <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
    </div>
    <div>
      <p class="text-sm font-semibold text-foreground"><%= t("ruby_cms.admin.analytics.exit_pages", default: "Exit Pages") %></p>
      <p class="text-xs text-muted-foreground"><%= t("ruby_cms.admin.analytics.exit_pages_subtitle", default: "Last page viewed per session") %></p>
    </div>
  </div>

  <% if @exit_pages.present? && @exit_pages.any? %>
    <% total = @exit_pages.values.sum.to_f %>
    <div class="divide-y divide-border/30">
      <% @exit_pages.first(8).each_with_index do |(page_name, count), idx| %>
        <% pct = total.positive? ? (count / total * 100).round(1) : 0 %>
        <%= link_to page_details_ruby_cms_admin_analytics_path(page_name:, start_date: @start_date, end_date: @end_date, period: @period),
                    class: "group relative flex items-center justify-between gap-3 px-4 py-2.5 hover:bg-muted/40 transition-colors" do %>
          <div class="absolute inset-y-0 left-0 bg-amber-500/5 transition-all" style="width: <%= pct %>%"></div>
          <div class="relative z-10 flex items-center gap-3 min-w-0">
            <span class="text-xs font-medium text-muted-foreground tabular-nums w-5 text-right flex-shrink-0"><%= idx + 1 %></span>
            <p class="text-sm text-foreground truncate group-hover:text-primary transition-colors"><%= page_name.to_s.humanize %></p>
          </div>
          <div class="relative z-10 flex items-center gap-2.5 flex-shrink-0">
            <span class="text-xs text-muted-foreground tabular-nums"><%= pct %>%</span>
            <span class="text-sm font-semibold tabular-nums text-foreground"><%= number_with_delimiter(count) %></span>
            <svg class="w-3.5 h-3.5 text-muted-foreground/40 group-hover:text-primary/60 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="flex flex-col items-center justify-center px-4 py-10 gap-2">
      <svg class="w-8 h-8 text-muted-foreground/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      <p class="text-sm font-medium text-foreground"><%= t("ruby_cms.admin.analytics.no_exit_pages", default: "No exit page data available.") %></p>
      <p class="text-xs text-muted-foreground">Track some traffic to see which pages visitors leave from</p>
    </div>
  <% end %>
</div>
