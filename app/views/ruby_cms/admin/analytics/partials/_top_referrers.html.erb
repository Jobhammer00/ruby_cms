<div class="ruby_cms-analytics__panel">
  <h3 class="ruby_cms-analytics__panel-title">
    <span class="ruby_cms-analytics__panel-icon ruby_cms-analytics__panel-icon--green">↗</span>
    <%= t("ruby_cms.admin.analytics.top_referrers", default: "Top referrers") %>
  </h3>
  <div class="ruby_cms-analytics__list">
    <% if @top_referrers.present? && @top_referrers.any? %>
      <% @top_referrers.first(6).each do |referrer, count| %>
        <div class="ruby_cms-analytics__item">
          <span class="ruby_cms-analytics__item-title ruby_cms-analytics__item-title--truncate" title="<%= referrer %>"><%= referrer %></span>
          <span class="ruby_cms-analytics__item-count"><%= number_with_delimiter(count) %></span>
        </div>
      <% end %>
    <% else %>
      <p class="ruby_cms-analytics__empty"><%= t("ruby_cms.admin.analytics.no_referrers", default: "No referrers recorded") %></p>
    <% end %>
  </div>
</div>
