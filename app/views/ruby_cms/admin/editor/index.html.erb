<%= content_for :title, "Visual editor" %>
<%= content_for :full_width, true %>

<%= tag.div(
  data: {
    controller: "ruby-cms--visual-editor",
    "ruby-cms--visual-editor-nonce-value": @nonce,
    "ruby-cms--visual-editor-allowed-origin-value": request.base_url,
    "ruby-cms--visual-editor-content-blocks-base-value": ruby_cms_admin_content_blocks_path,
    "ruby-cms--visual-editor-csrf-token-value": form_authenticity_token,
    "ruby-cms--visual-editor-preview-path-value": ruby_cms_admin_editor_preview_path
  },
  class: "ruby_cms-visual-editor"
) do %>

  <%= tag.div class: "ruby_cms-visual-editor-main" do %>
    <%# Content Blocks Sidebar %>
    <%= tag.aside class: "ruby_cms-content-blocks-sidebar" do %>
      <%= tag.div class: "ruby_cms-content-blocks-header" do %>
        <%= tag.div class: "ruby_cms-component-palette-title" do %>
          <%= tag.h3 "Content Blocks" %>
          <%= tag.span @content_blocks.count, class: "ruby_cms-component-count" %>
        <% end %>
        <% if @page_keys.any? %>
          <%= tag.div style: "display: flex; align-items: center; gap: 0.5rem; margin-top: 1rem;" do %>
            <%= label_tag "editor-page-key", "Page", style: "font-size: 0.875rem; font-weight: 500; color: #374151;" %>
            <%= select_tag "editor-page-key",
                options_for_select(@page_keys.map { |k| [k, k] }, @page_key),
                id: "editor-page-key",
                class: "ruby_cms-input",
                style: "flex: 1;",
                data: { 
                  action: "change->ruby-cms--visual-editor#handlePageKeyChange",
                  ruby_cms__visual_editor_target: "pageKeySelect"
                } %>
          <% end %>
        <% end %>
      <% end %>

      <%= tag.div class: "ruby_cms-content-blocks-list" do %>
        <% @content_blocks.each do |block| %>
          <%= tag.div(
            class: "ruby_cms-content-block-card",
            data: { 
              content_block_id: block.id,
              content_block_key: block.key,
              action: "click->ruby-cms--visual-editor#selectContentBlock"
            }
          ) do %>
            <%= tag.h4 block.title.presence || block.key.humanize, class: "ruby_cms-content-block-title" %>
            <%= tag.p truncate(block.content.to_s, length: 100), class: "ruby_cms-content-block-text" %>
            <%= tag.div class: "ruby_cms-content-block-meta" do %>
              <%= tag.div class: "ruby_cms-content-block-badges" do %>
                <%= tag.span block.content_type.humanize,
                    class: "ruby_cms-badge ruby_cms-badge-type--#{block.content_type}" %>
                <%= tag.span (block.published? ? "Live" : "Draft"),
                    class: "ruby_cms-badge #{block.published? ? 'ruby_cms-badge-published' : 'ruby_cms-badge-draft'}" %>
              <% end %>
              <%= tag.span "#{time_ago_in_words(block.updated_at)} ago", class: "ruby_cms-content-block-time" %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>

    <%# Preview Area %>
    <% if @page_keys.any? %>
      <%= tag.main class: "ruby_cms-preview-area" do %>
        <%= tag.iframe(
          id: "preview-frame",
          src: ruby_cms_admin_editor_preview_path(page_key: @page_key, nonce: @nonce),
          class: "ruby_cms-preview-frame",
          sandbox: "allow-same-origin allow-scripts",
          referrerpolicy: "same-origin",
          data: { ruby_cms__visual_editor_target: "previewFrame" }
        ) %>
      <% end %>
    <% else %>
      <%= tag.main class: "ruby_cms-preview-area", style: "display: flex; align-items: center; justify-content: center;" do %>
        <%= tag.div class: "ruby_cms-text-center", style: "padding: 2rem;" do %>
          <%= tag.h3 "No pages configured", style: "font-size: 1.125rem; font-weight: 600; color: #111827; margin: 0 0 0.5rem 0;" %>
          <%= tag.p style: "color: #4b5563; max-width: 28rem;" do %>
            Create a page under <strong>Admin → Pages</strong> or configure pages in
            <code style="background: #f3f4f6; padding: 0.25rem 0.5rem; border-radius: 0.25rem;">config/initializers/ruby_cms.rb</code>.
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= tag.div id: "editor-modal",
      class: "ruby_cms-modal-overlay ruby_cms-hidden",
      data: { ruby_cms__visual_editor_target: "editModal" } do %>
    <%= tag.div class: "ruby_cms-modal" do %>
      <%= tag.div class: "ruby_cms-modal-header" do %>
        <%= tag.div do %>
          <%= tag.h3 "Edit Content Block", class: "ruby_cms-modal-title" %>
          <%= tag.p class: "ruby_cms-modal-subtitle" do %>
            <%= tag.span "Key: " %>
            <%= tag.span "", class: "ruby_cms-modal-key", data: { ruby_cms__visual_editor_target: "editModalKey" } %>
          <% end %>
        <% end %>
        <%= button_tag type: "button",
            class: "ruby_cms-modal-close",
            data: { action: "click->ruby-cms--visual-editor#hideModal", ruby_cms__visual_editor_target: "modalClose" } do %>
          <svg class="ruby_cms-modal-close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        <% end %>
      <% end %>

      <%= form_tag "#", method: :patch, local: false, data: { 
        action: "submit->ruby-cms--visual-editor#saveContentBlock",
        ruby_cms__visual_editor_target: "editForm"
      }, style: "display: flex; flex-direction: column; flex: 1; min-height: 0;" do %>
        <%= tag.div class: "ruby_cms-modal-body" do %>
          <%= tag.div style: "display: flex; flex-direction: column; gap: 1.5rem;" do %>
            <%= hidden_field_tag "block-id", "", data: { ruby_cms__visual_editor_target: "blockId" } %>
            <%= tag.div class: "ruby_cms-hidden" do %>
              <%= text_field_tag "block-key", "", 
                  id: "editor-block-key",
                  class: "ruby_cms-input",
                  readonly: true,
                  data: { ruby_cms__visual_editor_target: "blockKey" } %>
            <% end %>
            <%= tag.div class: "ruby_cms-modal-form-group" do %>
              <%= label_tag "block-title", "Title", class: "ruby_cms-modal-label" %>
              <%= text_field_tag "block-title", "",
                  id: "editor-block-title",
                  class: "ruby_cms-modal-input",
                  data: { ruby_cms__visual_editor_target: "blockTitle" } %>
            <% end %>
            <%= tag.div class: "ruby_cms-modal-form-group" do %>
              <%= label_tag "block-content-type", "Content type", class: "ruby_cms-modal-label" %>
              <%= select_tag "block-content-type",
                  options_for_select(RubyCms::ContentBlock::CONTENT_TYPES.map { |t| [t.humanize, t] }),
                  id: "editor-block-content-type",
                  class: "ruby_cms-modal-select",
                  data: { ruby_cms__visual_editor_target: "blockContentType" } %>
            <% end %>
            <%= tag.div class: "ruby_cms-modal-form-group" do %>
              <%= label_tag "block-content", "Content", class: "ruby_cms-modal-label" %>
              <%= text_area_tag "block-content", "",
                  id: "editor-block-content",
                  rows: 10,
                  class: "ruby_cms-modal-textarea",
                  data: { ruby_cms__visual_editor_target: "blockContent" } %>
            <% end %>
            <% if RubyCms::ContentBlock.respond_to?(:action_text_available?) && RubyCms::ContentBlock.action_text_available? %>
              <%= tag.div class: "ruby_cms-hidden" do %>
                <%= label_tag "block-rich-content", "Rich content (HTML)", class: "ruby_cms-modal-label" %>
                <%= text_area_tag "block-rich-content", "",
                    id: "editor-block-rich-content",
                    rows: 8,
                    class: "ruby_cms-modal-textarea",
                    data: { ruby_cms__visual_editor_target: "blockRichContent" } %>
              <% end %>
            <% end %>
            <%= tag.div style: "display: flex; align-items: center;" do %>
              <%= check_box_tag "block-published", "1", false,
                  id: "editor-block-published",
                  style: "width: 1rem; height: 1rem;",
                  data: { ruby_cms__visual_editor_target: "blockPublished" } %>
              <%= label_tag "editor-block-published", "Published", style: "margin-left: 0.5rem; font-size: 0.875rem; font-weight: 500; color: #374151;" %>
            <% end %>
          <% end %>
        <% end %>

        <%= tag.div class: "ruby_cms-modal-footer" do %>
          <%= button_tag "Cancel", type: "button",
              class: "ruby_cms-btn-cancel",
              data: { action: "click->ruby-cms--visual-editor#hideModal" } %>
          <%= submit_tag "Save Changes", class: "ruby_cms-btn-save-modal" %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
