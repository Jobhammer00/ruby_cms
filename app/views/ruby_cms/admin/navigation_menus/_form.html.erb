<%= form_with model: @menu, url: @menu.persisted? ? ruby_cms_admin_navigation_menu_path(@menu) : ruby_cms_admin_navigation_menus_path, method: (@menu.persisted? ? :patch : :post), class: "space-y-4 max-w-2xl" do |f| %>
  <% if @menu.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4">
      <ul class="list-disc list-inside text-sm text-red-800">
        <% @menu.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="ruby_cms-field">
    <%= f.label :key, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :key, class: "ruby_cms-input block w-full rounded-md border border-gray-300 px-3 py-2", placeholder: "main" %>
    <p class="mt-1 text-xs text-gray-500">Unique identifier for this menu (e.g. main, footer). Use in views: render_navigation_menu('main')</p>
  </div>

  <div class="ruby_cms-field">
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "ruby_cms-input block w-full rounded-md border border-gray-300 px-3 py-2", placeholder: "Main Navigation" %>
  </div>

  <div class="ruby_cms-field">
    <%= f.label :position, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :position, class: "ruby_cms-input block w-full rounded-md border border-gray-300 px-3 py-2", min: 0, step: 1 %>
  </div>

  <div class="flex items-center">
    <%= f.check_box :published, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
    <%= f.label :published, class: "ml-2 block text-sm text-gray-700" %>
  </div>

  <div class="pt-2">
    <%= f.submit class: "ruby_cms-btn ruby_cms-btn-primary inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700" %>
  </div>
<% end %>
