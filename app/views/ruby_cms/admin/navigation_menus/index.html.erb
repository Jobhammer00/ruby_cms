<%= content_for :title, "Navigation menus" %>

<div class="ruby_cms-page-header flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Navigation menus</h1>
  <%= link_to "New menu", new_ruby_cms_admin_navigation_menu_path, class: "ruby_cms-btn ruby_cms-btn-primary" %>
</div>

<% if @menus.any? %>
  <div class="ruby_cms-card ruby_cms-card--padded">
    <table class="ruby_cms-table">
      <thead>
        <tr>
          <th>Key</th>
          <th>Name</th>
          <th>Items</th>
          <th>Published</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @menus.each do |menu| %>
          <tr>
            <td><%= menu.key %></td>
            <td><%= menu.name %></td>
            <td><%= menu.navigation_items.count %></td>
            <td><%= menu.published? ? "Yes" : "No" %></td>
            <td>
              <%= link_to "View", ruby_cms_admin_navigation_menu_path(menu), class: "text-blue-600 hover:text-blue-800" %>
              <%= link_to "Edit", edit_ruby_cms_admin_navigation_menu_path(menu), class: "text-blue-600 hover:text-blue-800 ml-2" %>
              <%= link_to "Delete", ruby_cms_admin_navigation_menu_path(menu), method: :delete, 
                  data: { turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-800 ml-2" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="ruby_cms-card ruby_cms-card--padded">
    <p class="text-gray-700">No navigation menus yet. <%= link_to "Create one", new_ruby_cms_admin_navigation_menu_path, class: "text-blue-600 hover:text-blue-800" %> to get started.</p>
  </div>
<% end %>
