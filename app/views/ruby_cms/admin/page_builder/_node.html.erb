<% 
  # Extract display text from props for preview
  props = node.props || {}
  display_text = props["text"] || props["title"] || props["heading"] || props["content"]
  component_name = node.component_key.split(".").last.humanize
%>
<%= tag.div(
  class: "ruby_cms-node",
  draggable: "true",
  data: {
    node_id: node.id,
    component_key: node.component_key,
    ruby_cms__page_builder_target: "node",
    action: "click->ruby-cms--page-builder#selectNode dragstart->ruby-cms--page-builder#handleNodeDragStart dragover->ruby-cms--page-builder#handleDragOver drop->ruby-cms--page-builder#handleDrop"
  }
) do %>
  <%= tag.div class: "ruby_cms-node-header" do %>
    <%= tag.div class: "ruby_cms-node-title" do %>
      <svg class="ruby_cms-node-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
      </svg>
      <%= tag.span component_name, class: "ruby_cms-node-name" %>
      <% if display_text.present? %>
        <%= tag.span truncate(display_text, length: 30), class: "ruby_cms-node-preview-text" %>
      <% end %>
    <% end %>
    <%= tag.div class: "ruby_cms-node-actions" do %>
      <%= button_tag type: "button",
          class: "ruby_cms-node-action-btn",
          title: "Edit properties",
          data: { 
            node_id: node.id,
            action: "click->ruby-cms--page-builder#editNode"
          } do %>
        <svg class="ruby_cms-node-action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
      <% end %>
      <%= button_tag type: "button",
          class: "ruby_cms-node-action-btn ruby_cms-node-action-btn--delete",
          title: "Delete component",
          data: { 
            node_id: node.id,
            action: "click->ruby-cms--page-builder#deleteNode"
          } do %>
        <svg class="ruby_cms-node-action-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
      <% end %>
    <% end %>
  <% end %>
  
  <%# Render nested children if any %>
  <% if node.children.any? %>
    <%= tag.div(
      class: "ruby_cms-node-children",
      data: { ruby_cms__page_builder_target: "nodeChildren" }
    ) do %>
      <% node.children.by_position.each do |child| %>
        <%= render "node", node: child %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
