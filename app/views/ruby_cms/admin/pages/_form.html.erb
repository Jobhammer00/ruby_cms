<%= form_with model: @page, url: @page.persisted? ? ruby_cms_admin_page_path(@page) : ruby_cms_admin_pages_path, method: (@page.persisted? ? :patch : :post), class: "space-y-4 max-w-2xl", data: { controller: "ruby-cms--page-form" } do |f| %>
  <%= hidden_field_tag :template_key, @template_key if @template_key.present? %>
  <% if @page.errors.any? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-4">
      <ul class="list-disc list-inside text-sm text-red-800">
        <% @page.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="ruby_cms-field">
    <%= f.label :key, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :key, class: "ruby_cms-input block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500", placeholder: "home" %>
    <p class="mt-1 text-xs text-gray-500">URL-friendly id (e.g. home, about). Used in /p/:key and the visual editor.</p>
  </div>

  <div class="ruby_cms-field">
    <%= f.label :render_mode, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :render_mode, 
        options_for_select([
          ["Builder (Page Builder)", "builder"],
          ["HTML (Raw HTML)", "html"],
          ["Template (Codebase View)", "template"]
        ], @page.render_mode || "builder"),
        {},
        class: "ruby_cms-select block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500",
        data: { 
          ruby_cms__page_form_target: "renderMode",
          action: "change->ruby-cms--page-form#toggleFields"
        } %>
    <p class="mt-1 text-xs text-gray-500">
      <strong>Builder:</strong> Use the visual page builder (no code required).<br>
      <strong>HTML:</strong> Store raw HTML in the database.<br>
      <strong>Template:</strong> Use a template file from your codebase.
    </p>
  </div>

  <div id="template-path-field" class="ruby_cms-field" style="<%= 'display: none;' unless @page.render_mode == 'template' %>" data-ruby-cms--page-form-target="templatePathField">
    <%= f.label :template_path, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :template_path, class: "ruby_cms-input block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500", placeholder: "pages/home" %>
    <p class="mt-1 text-xs text-gray-500">View path without extension. Create this template in your app (e.g. app/views/pages/home.html.erb).</p>
  </div>

  <div id="body-html-field" class="ruby_cms-field" style="<%= 'display: none;' unless @page.render_mode == 'html' %>" data-ruby-cms--page-form-target="bodyHtmlField">
    <%= f.label :body_html, "HTML Content", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :body_html, rows: 10, class: "ruby_cms-textarea block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 font-mono text-sm", placeholder: "<h1>Your HTML here</h1>" %>
    <p class="mt-1 text-xs text-gray-500">Raw HTML content. Will be sanitized when rendered.</p>
  </div>

  <div id="builder-hint" class="rounded-lg bg-blue-50 border border-blue-200 p-3" style="<%= 'display: none;' unless @page.render_mode == 'builder' %>" data-ruby-cms--page-form-target="builderHint">
    <p class="text-sm text-blue-800">
      <strong>Builder mode:</strong> Save this page, then use the "Builder" button to visually build your page with components.
    </p>
  </div>

  <div class="ruby_cms-field">
    <%= f.label :layout, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :layout, class: "ruby_cms-input block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500", placeholder: "application (optional)" %>
    <p class="mt-1 text-xs text-gray-500">Layout name (optional). Defaults to <code>application</code> if not specified.</p>
  </div>

  <div class="ruby_cms-field">
    <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, class: "ruby_cms-input block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500", placeholder: "Home" %>
  </div>
  <div class="ruby_cms-field">
    <%= f.label :position, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.number_field :position, class: "ruby_cms-input block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500", min: 0, step: 1 %>
  </div>
  <div class="flex items-center">
    <%= f.check_box :published, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
    <%= f.label :published, class: "ml-2 block text-sm text-gray-700" %>
  </div>

  <div class="pt-2">
    <%= f.submit class: "ruby_cms-btn ruby_cms-btn-primary inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700" %>
  </div>
<% end %>
