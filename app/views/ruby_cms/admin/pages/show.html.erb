<%= content_for :title, @page.title.presence || @page.key %>

<div class="ruby_cms-page-header flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900"><%= @page.title.presence || @page.key %></h1>
  <div class="flex items-center gap-2">
    <% if @page.builder_mode? %>
      <%= link_to "Builder", builder_ruby_cms_admin_page_path(@page), class: "ruby_cms-btn ruby_cms-btn-primary" %>
    <% end %>
    <%= link_to "Edit", edit_ruby_cms_admin_page_path(@page), class: "ruby_cms-btn ruby_cms-btn-secondary" %>
    <%= link_to "View", "/p/#{@page.key}", target: "_blank", class: "ruby_cms-btn ruby_cms-btn-secondary" %>
  </div>
</div>

<div class="ruby_cms-card ruby_cms-card--padded max-w-2xl">
  <dl class="grid gap-3">
    <div>
      <dt class="text-sm font-medium text-gray-500">Key</dt>
      <dd class="text-gray-900"><%= @page.key %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Render Mode</dt>
      <dd class="text-gray-900">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= 
          case @page.render_mode
          when 'builder'
            'bg-blue-100 text-blue-800'
          when 'html'
            'bg-green-100 text-green-800'
          when 'template'
            'bg-purple-100 text-purple-800'
          else
            'bg-gray-100 text-gray-800'
          end
        %>">
          <%= @page.render_mode.humanize %>
        </span>
      </dd>
    </div>
    <% if @page.template_mode? && @page.template_path.present? %>
      <div>
        <dt class="text-sm font-medium text-gray-500">Template path</dt>
        <dd class="text-gray-900"><%= @page.template_path %></dd>
      </div>
    <% end %>
    <% if @page.html_mode? && @page.body_html.present? %>
      <div>
        <dt class="text-sm font-medium text-gray-500">HTML Content</dt>
        <dd class="text-gray-900">
          <pre class="text-xs bg-gray-50 p-2 rounded overflow-auto max-h-32"><%= truncate(@page.body_html, length: 200) %></pre>
        </dd>
      </div>
    <% end %>
    <% if @page.layout.present? %>
      <div>
        <dt class="text-sm font-medium text-gray-500">Layout</dt>
        <dd class="text-gray-900"><%= @page.layout %></dd>
      </div>
    <% end %>
    <div>
      <dt class="text-sm font-medium text-gray-500">Title</dt>
      <dd class="text-gray-900"><%= @page.title.presence || "—" %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Published</dt>
      <dd><%= @page.published? ? "Yes" : "No" %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Position</dt>
      <dd class="text-gray-900"><%= @page.position %></dd>
    </div>
  </dl>
</div>
