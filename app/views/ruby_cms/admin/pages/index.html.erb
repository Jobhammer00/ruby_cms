<%= content_for :title, "Pages" %>

<div class="ruby_cms-page-header flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Pages</h1>
  <%= link_to "New page", new_ruby_cms_admin_page_path, class: "ruby_cms-btn ruby_cms-btn-primary inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700" %>
</div>

<% if @pages.empty? %>
  <div class="ruby_cms-card ruby_cms-card--padded">
    <p class="text-gray-700" style="margin:0 0 0.75rem 0;">
      Create a page with key <code>home</code> and template_path <code>pages/home</code>, then add <code>app/views/pages/home.html.erb</code> in your app.
    </p>
    <p class="text-gray-600 text-sm" style="margin:0;">
      You can also set <code>config.ruby_cms.preview_templates = { "home" =&gt; "pages/home" }</code> in <code>config/initializers/ruby_cms.rb</code> instead.
    </p>
  </div>
<% else %>
  <div class="ruby_cms-card ruby_cms-table-wrap bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
    <table class="ruby_cms-table min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Key</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Template</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Title</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Published</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @pages.each do |page| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-sm text-gray-900"><%= page.key %></td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= page.template_path %></td>
            <td class="px-4 py-3 text-sm text-gray-900"><%= page.title %></td>
            <td class="px-4 py-3 text-sm"><%= page.published? ? tag.span("Yes", class: "ruby_cms-badge ruby_cms-badge-success px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800") : tag.span("No", class: "ruby_cms-badge ruby_cms-badge-muted px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600") %></td>
            <td class="actions px-4 py-3 text-sm text-right space-x-2">
              <%= link_to "Show", ruby_cms_admin_page_path(page), class: "ruby_cms-link text-blue-600 hover:text-blue-800" %>
              <%= link_to "Edit", edit_ruby_cms_admin_page_path(page), class: "ruby_cms-link text-blue-600 hover:text-blue-800" %>
              <%= link_to "Open in builder", builder_ruby_cms_admin_page_path(page), class: "ruby_cms-link text-blue-600 hover:text-blue-800 font-medium" %>
              <%= button_to "Delete", ruby_cms_admin_page_path(page), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "ruby_cms-link ruby_cms-link-danger inline text-red-600 hover:text-red-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
